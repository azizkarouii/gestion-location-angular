rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    match /locataires/{locataireId} {
      allow create: if isOwner(request.resource.data.ownerId);
      allow read, delete: if isOwner(resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.ownerId == resource.data.ownerId;
    }

    match /paiements/{paiementId} {
      allow create: if isOwner(request.resource.data.ownerId);
      allow read, delete: if isOwner(resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.ownerId == resource.data.ownerId;
    }

    match /proprietaires/{ownerId} {
      allow create: if signedIn()
        && request.auth.uid == ownerId
        && request.resource.data.ownerId == request.auth.uid;
      allow read, delete: if signedIn() && request.auth.uid == ownerId;
      allow update: if signedIn()
        && request.auth.uid == ownerId
        && request.resource.data.ownerId == resource.data.ownerId;
    }
  }
}
